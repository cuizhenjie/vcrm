# ---- 数据库（SQLite，零配置）----
DATABASE_URL="file:./dev.db"

# ---- 短信通道：mock(本地无凭证可跑) | lianlu(真实联麓通道) ----
SMS_PROVIDER="mock"

# ---- 联麓凭证（SMS_PROVIDER=lianlu 时必填，字段以控制台 api_4_2 文档为准 ⚠）----
LIANLU_BASE_URL="https://api.shlianlu.com"
LIANLU_ACCOUNT=""
LIANLU_API_KEY=""
LIANLU_SIGN="【你的签名】"

# ---- 本站地址（生成短链/回调用）----
APP_BASE_URL="http://localhost:3000"

# ---- 发送限速（条/秒），按通道并发能力调整 ----
SEND_RATE_PER_SEC="20"
