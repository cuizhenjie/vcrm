# ---- 数据库（SQLite，零配置）----
DATABASE_URL="file:./dev.db"

# ---- 短信通道：mock(本地无凭证可跑) | lianlu(真实短信通道) ----
SMS_PROVIDER="mock"

# ---- 联麓凭证（SMS_PROVIDER=lianlu 时必填，按官方 Signature 文档命名）----
LIANLU_BASE_URL="https://apis.shlianlu.com"
LIANLU_MCH_ID=""
LIANLU_APP_ID=""
LIANLU_API_KEY=""
LIANLU_SIGN_NAME="【你的短信签名】"
LIANLU_VERSION="1.2.0"
LIANLU_MESSAGE_TYPE="1"

# ---- 本站地址（生成短链/回调用）----
APP_BASE_URL="http://localhost:3000"

# ---- 发送限速（条/秒），按通道并发能力调整 ----
SEND_RATE_PER_SEC="20"

# ---- ROI 成本模型：每条短信单价（元/条，非法/负值回退 0.05；可设 0 表示免费通道）----
SMS_UNIT_COST="0.05"

# ---- 避扰时段（24h，跨午夜自动处理；默认 22:00-08:00 不发）----
QUIET_START="22"
QUIET_END="8"

# ---- 定时任务触发密钥（外部 cron 调 /api/cron/tick 时校验）----
CRON_SECRET=""

# ---- 联麓端点/响应字段（⚠ 发送路径与响应结构以联麓发送 API 文档或联调为准）----
LIANLU_SEND_PATH="/sms/product/sendSMS"
LIANLU_BALANCE_PATH="/sms/product/balance"
# 以下路径联麓文档未确认，留空则对应功能自动降级（不调用）
LIANLU_MMS_PATH=""
LIANLU_FLASH_PATH=""
LIANLU_CHECK_PATH=""
LIANLU_QUERY_PATH=""
# 成功判定（默认 code=="0"）与消息/余额字段名（联调后按真实响应调整）
LIANLU_SUCCESS_FIELD="code"
LIANLU_SUCCESS_VALUE="0"
LIANLU_MESSAGE_ID_FIELD=""
LIANLU_BALANCE_FIELD="balance"
LIANLU_TIMEOUT_MS="10000"

# ---- A/B 自动放量：每个变体测试阶段最小样本量（达不到不判显著）----
AB_MIN_SAMPLE="30"

# ---- 登录认证（MVP 单管理员）----
APP_PASSWORD="admin"
AUTH_SECRET="change-me-to-a-long-random-string"
