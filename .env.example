# ---- 数据库（SQLite，零配置）----
DATABASE_URL="file:./dev.db"

# ---- 短信通道：mock(本地无凭证可跑) | lianlu(真实联麓通道) ----
SMS_PROVIDER="mock"

# ---- 联麓凭证（SMS_PROVIDER=lianlu 时必填，字段以控制台 api_4_2 文档为准 ⚠）----
LIANLU_BASE_URL="https://api.shlianlu.com"
LIANLU_ACCOUNT=""
LIANLU_API_KEY=""
LIANLU_SIGN="【你的签名】"

# ---- 本站地址（生成短链/回调用）----
APP_BASE_URL="http://localhost:3000"

# ---- 发送限速（条/秒），按通道并发能力调整 ----
SEND_RATE_PER_SEC="20"

# ---- 避扰时段（24h，跨午夜自动处理；默认 22:00-08:00 不发）----
QUIET_START="22"
QUIET_END="8"

# ---- 定时任务触发密钥（外部 cron 调 /api/cron/tick 时校验）----
CRON_SECRET=""

# ---- 联麓可配置端点/签名（⚠ 全部以控制台 api_4_2 文档为准）----
LIANLU_SEND_PATH="/sms/send"
LIANLU_MMS_PATH="/mms/send"
LIANLU_FLASH_PATH="/flash/send"
LIANLU_CHECK_PATH="/empty/check"
LIANLU_QUERY_PATH="/sms/query"
LIANLU_BALANCE_PATH="/account/balance"
LIANLU_SIGN_ALGO="md5"
LIANLU_SUCCESS_FIELD="code"
LIANLU_SUCCESS_VALUE="0"

# ---- A/B 自动放量：每个变体测试阶段最小样本量（达不到不判显著）----
AB_MIN_SAMPLE="30"
